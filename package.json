{
  "name": "passion-seed",
  "version": "1.0.0",
  "main": "expo-router/entry",
"scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node --experimental-strip-types node_modules/@shopify/react-native-skia/scripts/install-libs.js",
    "generate:pathlab": "npx tsx scripts/generate-pathlab/index.ts",
    "generate:pathlab:batch": "npx tsx scripts/generate-pathlab/batch.ts",
    "build:android-local": "GOOGLE_SERVICES_JSON=$(pwd)/google-services.json eas build --local -p android"
  },
  "dependencies": {
    "@expo-google-fonts/bai-jamjuree": "^0.4.1",
    "@expo-google-fonts/google-sans": "^0.4.0",
